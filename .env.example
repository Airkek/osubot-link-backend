OSU_OAUTH_CLIENT_ID=12345
OSU_OAUTH_CLIENT_SECRET=secret
OSU_OAUTH_REDIRECT_URL=https://link.example.com/callback
BOT_LINK_COMMAND=s link
LINK_DB_HOST=link_db
